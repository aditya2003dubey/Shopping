<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
        }

        header {
            background: linear-gradient(90deg, #ff7eb3, #ff758c);
            color: #fff;
            padding: 1rem 0;
            text-align: center;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ff758c;
            padding: 0.5rem 1rem;
            flex-wrap: wrap;
        }

        nav .logo {
            font-size: 1.5rem;
            color: #fff;
            font-weight: bold;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            margin: 0 1rem;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .about-section {
            padding: 2rem;
            background: #f4f4f4;
            text-align: center;
        }

        .about-section h1 {
            margin-bottom: 1rem;
            color: #333;
        }

        .about-section p {
            margin: 1rem 0;
            color: #555;
        }

        .team {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            padding: 2rem;
        }

        .team-member {
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            text-align: center;
            padding: 1rem;
        }

        .team-member img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-bottom: 1px solid #ddd;
        }

        .team-member h3 {
            margin: 1rem 0 0.5rem;
            color: #333;
        }

        .team-member p {
            color: #777;
        }

        footer {
            text-align: center;
            padding: 1rem;
            background: #333;
            color: #fff;
            margin-top: 2rem;
        }

        @media (max-width: 768px) {
            .about-section {
                padding: 1rem;
            }

            .team {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header>
        <h1>About Us</h1>
    </header>
    <nav>
        <div class="logo">E-Shop</div>
          <div>
              <a href="/">Home</a>
              <a href="/about">About</a>
              <a href="/contact">Contact</a>
              <a href="/cart">Cart</a>
          </div>
      </nav>
    <section class="about-section">
        <h1>Welcome to Our E-commerce Store</h1>
        <p>We are dedicated to providing you with the best products and services. Our mission is to deliver quality and satisfaction to all our customers.</p>
        <p>With a wide range of products and a passionate team, we aim to make your shopping experience delightful and hassle-free.</p>
    </section>
    <section class="team">
        <div class="team-member">
            <img src="https://via.placeholder.com/300" alt="Team Member 1">
            <h3>John Doe</h3>
            <p>Founder & CEO</p>
        </div>
        <div class="team-member">
            <img src="https://via.placeholder.com/300" alt="Team Member 2">
            <h3>Jane Smith</h3>
            <p>Chief Marketing Officer</p>
        </div>
        <div class="team-member">
            <img src="https://via.placeholder.com/300" alt="Team Member 3">
            <h3>Emily Johnson</h3>
            <p>Head of Design</p>
        </div>
        <div class="team-member">
            <img src="https://via.placeholder.com/300" alt="Team Member 4">
            <h3>Michael Brown</h3>
            <p>Lead Developer</p>
        </div>
    </section>
    <footer>
        <p>&copy; 2025 My E-commerce Store. All rights reserved.</p>
    </footer>
</body>
</html>
