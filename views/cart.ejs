<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart Checkout</title>
    <style>
        /* General styling */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    background-color: #f9f9f9;
    color: #333;
}

.container {
    width: 90%;
    margin: auto;
    padding: 20px;
    max-width: 1200px;
}

.header {
    text-align: center;
    color: #5a5a5a;
    margin-bottom: 20px;
}
nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ff758c;
            padding: 0.5rem 1rem;
            flex-wrap: wrap;
            height: 3rem;
            margin-bottom: 1rem;
        }

        nav .logo {
            font-size: 1.5rem;
            color: #fff;
            font-weight: bold;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            margin: 0 1rem;
        }

        nav a:hover {
            text-decoration: underline;
        }

.cart {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.cart-item {
    display: flex;
    justify-content: space-between;
    padding: 15px;
    background-color: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
}

.cart-item img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 5px;
}

.item-details {
    flex: 1;
    margin-left: 15px;
}

h3 {
    font-size: 18px;
    color: #2c3e50;
}

p {
    margin: 5px 0;
    color: #7f8c8d;
}

.quantity {
    width: 60px;
    padding: 5px;
    margin-top: 10px;
}

.remove-btn {
    background-color: #e74c3c;
    color: #fff;
    border: none;
    padding: 8px 15px;
    cursor: pointer;
    border-radius: 5px;
    transition: background-color 0.3s;
}

.remove-btn:hover {
    background-color: #c0392b;
}

.checkout-summary {
    background-color: #fff;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    margin-top: 30px;
}

.summary-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
}

.summary-item p {
    font-size: 18px;
}

.subtotal, .shipping, .total {
    font-weight: bold;
}

.checkout-btn {
    width: 100%;
    padding: 15px;
    background-color: #27ae60;
    color: #fff;
    border: none;
    font-size: 18px;
    cursor: pointer;
    border-radius: 8px;
    transition: background-color 0.3s;
}

.checkout-btn:hover {
    background-color: #2ecc71;
}

/* Responsive styling */
@media (max-width: 768px) {
    .cart-item {
        flex-direction: column;
        align-items: center;
    }

    .item-details {
        text-align: center;
        margin-left: 0;
    }

    .checkout-summary {
        margin-top: 20px;
    }

    .checkout-btn {
        padding: 12px;
        font-size: 16px;
    }
}

    </style>
</head>
<body>
    <div class="container">
        <nav>
            <div class="logo">E-Shop</div>
              <div>
                  <a href="/">Home</a>
                  <a href="/about">About</a>
                  <a href="/contact">Contact</a>
                  <a href="/cart">Cart</a>
              </div>
          </nav>
        <h1 class="header">Checkout</h1>
        <div class="cart">
            <div class="cart-item">
                <img src="https://via.placeholder.com/100" alt="Product Image">
                <div class="item-details">
                    <h3>Product Name</h3>
                    <p>$25.99</p>
                    <input type="number" value="1" class="quantity">
                </div>
                <button class="remove-btn">Remove</button>
            </div>

            <div class="cart-item">
                <img src="https://via.placeholder.com/100" alt="Product Image">
                <div class="item-details">
                    <h3>Another Product</h3>
                    <p>$15.49</p>
                    <input type="number" value="1" class="quantity">
                </div>
                <button class="remove-btn">Remove</button>
            </div>
        </div>

        <div class="checkout-summary">
            <div class="summary-item">
                <p>Subtotal:</p>
                <p class="subtotal">$41.48</p>
            </div>
            <div class="summary-item">
                <p>Shipping:</p>
                <p class="shipping">$5.00</p>
            </div>
            <div class="summary-item">
                <p>Total:</p>
                <p class="total">$46.48</p>
            </div>

            <button class="checkout-btn">Proceed to Checkout</button>
        </div>
    </div>

    <script >
        document.querySelectorAll('.remove-btn').forEach(button => {
    button.addEventListener('click', function () {
        this.closest('.cart-item').remove();
        updateSummary();
    });
});

document.querySelectorAll('.quantity').forEach(input => {
    input.addEventListener('input', function () {
        updateSummary();
    });
});

function updateSummary() {
    let subtotal = 0;
    document.querySelectorAll('.cart-item').forEach(item => {
        const price = parseFloat(item.querySelector('p').textContent.replace('$', ''));
        const quantity = item.querySelector('.quantity').value;
        subtotal += price * quantity;
    });

    const shipping = 5.00;
    const total = subtotal + shipping;

    document.querySelector('.subtotal').textContent = `$${subtotal.toFixed(2)}`;
    document.querySelector('.shipping').textContent = `$${shipping.toFixed(2)}`;
    document.querySelector('.total').textContent = `$${total.toFixed(2)}`;
}

updateSummary();

    </script>
</body>
</html>
