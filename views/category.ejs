<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
        }

        header {
            background: linear-gradient(90deg, #ff7eb3, #ff758c);
            color: #fff;
            padding: 1rem 0;
            text-align: center;
        }
        #sub-header{
            background: linear-gradient(90deg, #501ce9, #ff758c);
            color: #fff;
            margin: 3rem 4rem 0.5rem 4rem;
            padding: 0.5rem 0;
            text-align: center;
            border-radius: 0.5rem;
        }
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ff758c;
            padding: 0.5rem 1rem;
            flex-wrap: wrap;
        }

        nav .logo {
            font-size: 1.5rem;
            color: #fff;
            font-weight: bold;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            margin: 0 1rem;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .search-bar {
            display: flex;
            align-items: center;
        }

        .search-bar input {
            padding: 0.5rem;
            border: none;
            border-radius: 5px;
            outline: none;
        }

        .search-bar button {
            padding: 0.5rem;
            margin-left: 0.5rem;
            background: #ff7eb3;
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .search-bar button:hover {
            background: #ff758c;
        }
        .products {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            padding: 1rem 2rem 2rem;
        }

        .product {
            border: 1px solid #ddd;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s;
            background: #fff;
        }

        .product:hover {
            transform: scale(1.05);
        }

        .product img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .product h3 {
            margin: 0.5rem;
            color: #333;
        }

        .product p {
            margin: 0.5rem;
            color: #777;
        }

        .product button {
            display: block;
            width: 90%;
            margin: 1rem auto;
            padding: 0.5rem;
            background: #ff7eb3;
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .product button:hover {
            background: #ff758c;
        }

        footer {
            text-align: center;
            padding: 1rem;
            background: #333;
            color: #fff;
            margin-top: 2rem;
        }
        a{
            text-decoration: none;
        }

        @media (max-width: 768px) {
            nav {
                flex-direction: column;
            }

            .search-bar {
                margin-top: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <header>
        <h1>E-commerce Store</h1>
    </header>
    <nav>
      <div class="logo">E-Shop</div>
      <div class="search-bar">
        <input type="text" id="search" placeholder="Search products...">
        <button onclick="searchProducts()">Search</button>
    </div>
        <div>
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
            <a href="/cart">Cart</a>
        </div>
    </nav>

    <header id="sub-header">
        <h3>Product Category</h3>
    </header>

    <section class="products">
        <a href="/product">
        <div class="product">
            <img src="https://images.unsplash.com/photo-1618898909019-010e4e234c55?q=80&w=1374&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Product 1">
            <h3>Product 1</h3>
            <p>$19.99</p>
            <button>Add to Cart</button>
        </div>
    </a>
        <div class="product">
            <img src="https://images.unsplash.com/photo-1551232864-3f0890e580d9?q=80&w=1374&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Product 2">
            <h3>Product 2</h3>
            <p>$29.99</p>
            <button>Add to Cart</button>
        </div>
        <div class="product">
            <img src="https://images.unsplash.com/photo-1523381294911-8d3cead13475?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Product 3">
            <h3>Product 3</h3>
            <p>$39.99</p>
            <button>Add to Cart</button>
        </div>
        <div class="product">
            <img src="https://images.unsplash.com/photo-1479064555552-3ef4979f8908?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Product 4">
            <h3>Product 4</h3>
            <p>$49.99</p>
            <button>Add to Cart</button>
        </div>
    </section>

    <footer>
        <p>&copy; 2025 My E-commerce Store. All rights reserved.</p>
    </footer>

    <script>
        function searchProducts() {
            const query = document.getElementById('search').value.toLowerCase();
            const products = document.querySelectorAll('.product');

            products.forEach(product => {
                const productName = product.querySelector('h3').innerText.toLowerCase();
                if (productName.includes(query)) {
                    product.style.display = 'block';
                } else {
                    product.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>