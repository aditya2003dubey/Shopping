<% layout("/layout/boilerplate") -%>
    <header>
        <h1>E-commerce Store</h1>
    </header>
    <nav>
      <div class="logo">E-Shop</div>
      <div class="search-bar">
        <input type="text" id="search" placeholder="Search products...">
        <button onclick="searchProducts()">Search</button>
    </div>
        <div>
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
            <a href="/cart">Cart</a>
            <span class="profile">
                <a href="/profile">
                <i class="bi bi-person-circle"></i>
            </a>
            <a href="/add_product/<%= category_id %>">
                <i class="bi bi-plus-circle"></i>
            </a>
        </span>
        </div>
    </nav>

    <header id="sub-header">
        <h3>Product Category</h3>
    </header>

    <section class="products">
        <% for(product of products_array){ %>
            
                <div class="product">
                    <a href="/product/<%= product._id %>">
                    <img src="<%= product.image.url %>">
                </a>
                    <h3><%= product.name %></h3>
                    <p>&#8377; <%= product.price.toLocaleString("en-In") %></p>
                    <button>Add to Cart</button>
                    <form action="/product/<%=product._id%>?_method=delete" method="post">
                    </button type="submit" class="btn"><button>
                    </form>
                </div>
            <% } %>
    </section>

    <footer>
        <p>&copy; 2025 My E-commerce Store. All rights reserved.</p>
    </footer>

    <script>
        function searchProducts() {
            const query = document.getElementById('search').value.toLowerCase();
            const products = document.querySelectorAll('.product');

            products.forEach(product => {
                const productName = product.querySelector('h3').innerText.toLowerCase();
                if (productName.includes(query)) {
                    product.style.display = 'block';
                } else {
                    product.style.display = 'none';
                }
            });
        }
    </script>
